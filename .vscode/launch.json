{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "mGBA Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Hello_World.elf",
            "args": [],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/devkitPro/devkitARM/bin/arm-none-eabi-gdb.exe",
            "miDebuggerServerAddress": "localhost:2345",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}