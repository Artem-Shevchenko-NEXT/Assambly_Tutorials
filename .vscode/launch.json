{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "mGBA Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/${input:tutorialFolder}/${input:tutorialFolder}.elf",
            "args": [],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/${input:tutorialFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/devkitPro/devkitARM/bin/arm-none-eabi-gdb.exe",
            "miDebuggerServerAddress": "localhost:2345",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ],
    "inputs": [
        {
            "id": "tutorialFolder",
            "type": "promptString",
            "description": "Enter the name of the tutorial folder you want to debug (e.g., Hello_World)",
            "default": "Hello_World"
        }
    ]
}